<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:OpticalChainSimulator.Views"
             xmlns:vm="using:OpticalChainSimulator.ViewModels"
             x:Class="OpticalChainSimulator.Views.Docks.SimulationToolView"
             x:DataType="vm:MainWindowViewModel">
  
  <Border Classes="Panel" Padding="10">
    <views:ProjectInfoControl  DataContext="{Binding $parent[Window].DataContext}"/>
  </Border>
</UserControl>