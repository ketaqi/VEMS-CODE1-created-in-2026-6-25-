<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OpticalChainSimulator"
             x:Class="OpticalChainSimulator.Views.Docks.ViewportDocumentView"
			 xmlns:vm="using:OpticalChainSimulator.ViewModels"
			x:DataType="vm:MainWindowViewModel"
			 >
<local:MainView x:Name="MainViewControl"  DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
</UserControl>