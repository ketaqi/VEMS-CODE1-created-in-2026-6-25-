<Window x:Class="VEMS.MLayers.MLayersAnalyzer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VEMS.MLayers"
        xmlns:vplt="clr-namespace:VEMS.Plot;assembly=VEMS.Plot"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1600">

    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition Width="7*"></ColumnDefinition>
            <ColumnDefinition Width="5"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="24"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Column="0" Grid.Row="1" Background="Silver"></Border>
        <Border Grid.Row="2" Grid.ColumnSpan="4" Background="LightSteelBlue"/>
        <GridSplitter Grid.Column="2" Grid.Row="1" Grid.RowSpan="1" Width="5" VerticalAlignment="Stretch"
                      HorizontalAlignment="Center"  ShowsPreview="True" />

        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Name="mainMenu" IsMainMenu="True" 
              Height="18" Foreground="Black" Background="Silver">
            <MenuItem Header="Layers" FontStyle="Italic" Foreground="Black"></MenuItem>
            <MenuItem Header="Files" >
                <MenuItem Header="Import from TXT" Click="ImportNTXT" ></MenuItem>
                <MenuItem Header="Linear Interpolation" Click="LinearInterpolation"></MenuItem>
                <MenuItem Header="Export to Excel" ></MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Edit_Blank1"></MenuItem>
                <MenuItem Header="Edit_Blank1"></MenuItem>
            </MenuItem>
            <MenuItem Header="Test">
                <MenuItem Header="Show Info" Click="MenuItem_ShowInfoClick"></MenuItem>
                <MenuItem Header="Compute Power Ratios" Click="MenuItem_ComputePowerRatios"/>
                <MenuItem Header="Compute Coefficients" Click="MenuItem_ComputeCoefficients"/>
                <MenuItem Header="8 degree" Click=" Com8degree"/>

                <MenuItem Header="Load Default Info" Click="MenuItem_LoadDefaultInfo"/>
            </MenuItem>
        </Menu>
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="2" 
                      BorderBrush="LightGray" BorderThickness="0.5"
                      VerticalScrollBarVisibility="Auto" >
            <StackPanel Margin="10,5,0,5" Orientation="Vertical">
                <Expander Margin="0,8,0,2" IsExpanded="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Optical Parameters
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid AlternationCount="2" Margin="0,8,0,8"  
                              Name="OpticalDataGrid" HeadersVisibility="Column" 
                              AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserDeleteRows="False" CanUserSortColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Wavelength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Wavelength [m]" Width="*"/>
                                <DataGridTextColumn Binding="{Binding MinIncidenceAngle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Minimum Angle [Deg]" Width="*"/>
                                <DataGridTextColumn Binding="{Binding MaxIncidenceAngle, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" Header="Maximum Angle [Deg]" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="0">
                                            <Setter Property="Background" Value="MediumAquamarine"/>
                                        </Trigger>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </StackPanel>
                </Expander>
                <Expander Margin="0,8,0,2" IsExpanded="True" >
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Layer Parameters
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid AlternationCount="2" Margin="0,8,0,8" 
                              Name="layerDataGrid" HeadersVisibility="Column" 
                              AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserDeleteRows="False"  CanUserSortColumns="False" >
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Index" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Thickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Thickness" Width="2*"/>
                                <DataGridTextColumn Binding="{Binding Material, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" Header="Material" Width="2*"/>
                                <DataGridTextColumn Binding="{Binding NRe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Re{n}" Width="*" />
                                <DataGridTextColumn Binding="{Binding NIm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Im{n}" Width="*" />
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="0">
                                            <Setter Property="Background" Value="MediumAquamarine"/>
                                        </Trigger>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Add" Margin="4"
                            Click="AddLayer" Name="addLayerButton" 
                            Foreground="Black"/>
                            <Button Grid.Column="1" Content="Delete" Margin="4"
                                    Click="DeleteLayers" Name="deleteLayerButton"/>
                            <Button Grid.Column="2" Content="Periodic" Margin="4"
                                    Click="AddPeriodicLayers" Name="addPeriodicLayerButton"/>
                        </Grid>
                    </StackPanel>
                </Expander>
                <Separator/>
                <Expander Margin="0,8,0,2" IsExpanded="False">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Sampling Parameters
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid AlternationCount="2" Margin="0,8,0,8"                              HeadersVisibility="Column" 
                              AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserDeleteRows="True" CanUserSortColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Thickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Item" Width="*"/>
                                <DataGridTextColumn Binding="{Binding MaterialName, Mode=TwoWay,  UpdateSourceTrigger=PropertyChanged}" Header="Value" Width="*" />
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="{x:Type DataGridRow}">
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="0">
                                            <Setter Property="Background" Value="CadetBlue"/>
                                        </Trigger>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="AliceBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Func #1" Margin="4"/>
                            <Button Grid.Column="1" Content="Func #2" Margin="4"/>
                            <Button Grid.Column="2" Content="Func #3" Margin="4"/>
                        </Grid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Column="3" Grid.Row="1" Margin="0,5,0,5" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--<Plot.GridFig1DLite />-->
            <vplt:GridFig1DControl Grid.Row="0" Grid.Column="0" Name="FigUpperLeft"/>
            <vplt:GridFig1DControl Grid.Row="0" Grid.Column="2" Name="FigUpperRight"/>
            <vplt:GridFig1DControl Grid.Row="2" Grid.Column="0" Name="FigBottomLeft"/>
            <vplt:GridFig1DControl Grid.Row="2" Grid.Column="2" Name="FigBottomRight"/>

        </Grid>

    </Grid>
</Window>
