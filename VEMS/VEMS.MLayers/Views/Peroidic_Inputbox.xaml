<Window x:Class="VEMS.MLayers.Peroidic_Inputbox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VEMS.MLayers"
        mc:Ignorable="d"
        Title="Peroidic Inputbox" Height="450" Width="600" WindowStartupLocation="CenterScreen" Background="MediumAquamarine" >
    <Grid>
        <StackPanel >
            <TextBlock Text="Number in each peroid" HorizontalAlignment="Center" Margin="10"/>
            <TextBox Name="NumberInPeroid" PreviewKeyDown="TextBox_PreviewKeyDown1"  PreviewTextInput="TextBox_PreviewTextInput" Width="100" Margin="5"
                     InputMethod.IsInputMethodEnabled="False"/>
            <TextBlock Text="Number of peroids" HorizontalAlignment="Center" Margin="10"/>
            <TextBox Name="NumberOfPeroids" PreviewKeyDown="TextBox_PreviewKeyDown2"  PreviewTextInput="TextBox_PreviewTextInput" Width="100" Margin="5"
                     InputMethod.IsInputMethodEnabled="False"/>
            <Button Content="Submit" Margin="5" Width="100" Click="Button_SetPeroidNumber"/>
            <StackPanel Name="StackOfData">
            </StackPanel>
            
        </StackPanel>
    </Grid>
</Window>
