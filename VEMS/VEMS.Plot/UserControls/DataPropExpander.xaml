<UserControl x:Class="VEMS.Plot.DataPropExpander"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VEMS.Plot" 
             d:DataContext="{d:DesignInstance Type=local:DataPropExpander}"
             mc:Ignorable="d" 
             d:DesignHeight="260" d:DesignWidth="260"
             Background="White">

    <Expander Margin="4,8,0,0">
        <Expander.Header>
            <TextBlock Name="HeaderTextBlock" Text="{Binding}" FontSize="12" 
                       Foreground="DimGray" FontWeight="SemiBold" >
            </TextBlock>
        </Expander.Header>
        <Grid Margin="0,4,0,4" ShowGridLines="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Content="Data Label"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin ="2" Height="20" 
                     Name="LabelTextBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="1" Content="Complex Part" Name="PartLabel"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="2" Height="20"
                      Name="PartComboBox" VerticalContentAlignment="Center">
            </ComboBox>
            <Label Grid.Row="2" Content="Visual Option"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="2" Height="20"
                      Name="VisualComboBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="3" Content="Line Thickness"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="2" Height="20"
                     Name="LineWidthTextBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="4" Content="Line Style"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Margin="2" Height="20"
                      Name="LineStyleComboBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="5" Content="Test Color"
                   Name="TestColorLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="TestColorComboBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="6" Content="Marker Size"/>
            <TextBox Grid.Row="6" Grid.Column="1" Margin="2" Height="20"
                     Name="MarkerSizeTextBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="7" Content="Marker Shape"/>
            <ComboBox Grid.Row="7" Grid.Column="1" Margin="2" Height="20"
                      Name="MarkerShapeComboBox" VerticalContentAlignment="Center"/>
            <Label Grid.Row="8" Content="Plot Color"/>
            <ComboBox Grid.Row="8" Grid.Column="1" Margin="2" Height="20"
                      Name="PlotColorComboBox" VerticalContentAlignment="Center"/>
            <!--<Label Grid.Row="9" Content="Test Color" />
            <ComboBox Grid.Row="9" Grid.Column="1" Margin="2" Height="20"
                      Name="TestComboBox" VerticalContentAlignment="Center"/>-->
        </Grid>
    </Expander>
    
</UserControl>
