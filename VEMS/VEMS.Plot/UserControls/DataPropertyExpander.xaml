<UserControl x:Class="VEMS.Plot.DataPropertyExpander"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VEMS.Plot"
             d:DataContext="{d:DesignInstance Type=local:DataPropertyExpander}"
             mc:Ignorable="d" Background="White"
             d:DesignHeight="360" d:DesignWidth="260">
    
    <Expander Margin="4,8,0,0">
        <Expander.Header>
            <TextBlock Name="HeaderTextBlock" Text="{Binding}" FontSize="12" 
                       Foreground="DimGray" FontWeight="SemiBold" >
            </TextBlock>
        </Expander.Header>
        <Grid Margin="0,4,0,4" ShowGridLines="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Content="Data Label" Name="Label"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin ="2" Height="20"
                     Name="LabelTextBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="1" Content="Visual Option"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="2" Height="20"
                      Name="VisualComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="2" Content="Complex Part" Name="PartLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="PartComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="3" Content="Line Thickness" Name="LineWidthLabel" Visibility="Collapsed"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                     Name="LineWidthTextBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="4" Content="Line Style" Name="LineStyleLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="LineStyleComboBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="5" Content="Line Color" Name="LineColorLabel" Visibility="Collapsed" />
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="LineColorComboBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="6" Content="Marker Size" Name="MarkerSizeLabel" Visibility="Collapsed"/>
            <TextBox Grid.Row="6" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                     Name="MarkerSizeTextBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="7" Content="Marker Shape" Name="MarkerShapeLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="7" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="MarkerShapeComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="8" Content="Marker Color" Name="MarkerColorLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="8" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="MarkerColorComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="9" Content="Plot Color" Name="PlotColorLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="9" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="PlotColorComboBox" VerticalContentAlignment="Center"/>
            
            <Label Grid.Row="10" Content="Fill Color" Name="FillColorLabel" Visibility="Collapsed"/>
            <ComboBox Grid.Row="10" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="FillColorComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="11" Content="Colormap" Name="ColormapLabel" Visibility="Collapsed" />
            <ComboBox Grid.Row="11" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="ColormapComboBox" VerticalContentAlignment="Center"/>

            <Label Grid.Row="12" Content="Smoothing" Name="SmoothLabel" Visibility="Collapsed" />
            <ComboBox Grid.Row="12" Grid.Column="1" Margin="2" Height="20" Visibility="Collapsed"
                      Name="SmoothComboBox" VerticalContentAlignment="Center"/>

        </Grid>
    </Expander>
    
</UserControl>
