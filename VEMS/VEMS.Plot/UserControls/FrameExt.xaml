<UserControl x:Class="VEMS.Plot.FrameExt"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VEMS.Plot"
             mc:Ignorable="d" Background="White"
             d:DesignHeight="600" d:DesignWidth="1080">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="b2v" />
        <Style TargetType="DataGrid" x:Key="DataGridStyle">
            <Style.Setters>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="HeadersVisibility" Value="None"/>
                <!--Setter Property="RowHeight" Value="22"/-->
                <Setter Property="VerticalGridLinesBrush" Value="LightGray"/>
                <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DataGridRow" x:Key="DataGridRowStyle">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock" x:Key="TextBlockStyle">
            <Style.Setters>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="Button" x:Key="ButtonStyle">
            <Style.Setters>
                <Setter Property="Background" Value="WhiteSmoke"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
                <Setter Property="Width" Value="72"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" Name="PlotColumn"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" Name="AdvColumn"/>
        </Grid.ColumnDefinitions>
        
        <local:FrameLite x:Name="FrameLite"/>
        <GridSplitter Grid.Column="1" Grid.Row="1" Width="5" Name="Splitter"
                      VerticalAlignment="Stretch" HorizontalAlignment="Center"
                      Background="Transparent" ShowsPreview="True">
        </GridSplitter>
        <ScrollViewer Grid.Column="2" Margin="2" Name="AdvOption"
                      BorderBrush="LightGray" BorderThickness="0.5"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=AdvCheckBox, Converter={StaticResource b2v}}">
            <StackPanel Margin="10,5,10,5" Orientation="Vertical">

                <Button Padding="2" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent"
                        Click="PlotButton">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Margin="2,0,2,0" Points="0,6 12,13 0,20 0,6" Fill="LightSteelBlue"
                                 Stroke="Black" StrokeThickness="2"></Polygon>
                        <TextBlock Margin="4" Foreground="Black"  FontSize="14" Text="Plot/Update" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Expander Margin="0,8,0,8" IsEnabled="True" >
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Data Sources
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel Name="DataSourcePanel" />
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            View Ranges
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid RowHeight="24" Margin="0,8,0,0" Name="RangeDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                            
                            
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                                <DataGridTemplateColumn Header="_Value" Width="3*" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayValue}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, Mode=TwoWay}" Loaded="EditingTextBox_Loaded" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn> 
                                <DataGridTextColumn Header="_Unit" Width="*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="4,0,4,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto X" Click="AutoXButton"/>
                            <Button Grid.Column="1" Margin="4,0,4,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto Y" Click="AutoYButton"/>
                            <Button Grid.Column="2" Margin="4,0,2,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto X+Y" Click="AutoXYButton"/>
                        </Grid>

                    </StackPanel>

                    
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Axis Ticks
                        </TextBlock>
                    </Expander.Header>
                    <DataGrid RowHeight="24" Margin="0,8,0,0" Name="TickDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                            <DataGridTextColumn Header="_Density" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                            <DataGridTextColumn Header="_Size" Width="1.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Title, Label and Legend
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid RowHeight="24" Margin="0,8,0,0" Name="TextDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                                <DataGridTextColumn Header="_Content" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                                <DataGridTextColumn Header="_Size" Width="1.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <CheckBox Margin ="0,8,0,0" VerticalContentAlignment="Center"
                                  Name="CheckBox_ShowLegend" Content="Show Legend" IsChecked="True"/>
                        <Grid Margin="0,4,0,0" Visibility="{Binding ElementName=CheckBox_ShowLegend, Path=IsChecked, Converter={StaticResource b2v}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                       Text="Legend Location" />
                            <ComboBox Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" Height="20"
                                      Name="ComboBox_LegendLocation" />
                            <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" 
                                       Text="Legend Font Size" />
                            <TextBox Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" Height="20"
                                     BorderThickness="1.5" BorderBrush="LightGray"
                                     Name="TextBox_LegendFontSize" Text="16"/>
                        </Grid>
                    </StackPanel>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Value Monitor
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        
                        <CheckBox Margin ="0,8,0,0" VerticalContentAlignment="Center"
                                  Name="Crosshair_Show" Content="Show Crosshair" IsChecked="False"/>
                        <DataGrid RowHeight="24" Margin="0,8,0,0" Name="CursorDataGrid" ItemsSource="{Binding}"
                                  Visibility="{Binding ElementName=Crosshair_Show, Path=IsChecked, Converter={StaticResource b2v}}"
                                  TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                                  Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                                  RowStyle="{StaticResource DataGridRowStyle}"> 
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                        ElementStyle="{StaticResource TextBlockStyle}"
                        Binding="{Binding Name}" />
                                <DataGridTextColumn Header="_Value" Width="2.5*" IsReadOnly="True"
                        ElementStyle="{StaticResource TextBlockStyle}"
                        Binding="{Binding DisplayValue}" />
                                <DataGridTextColumn Header="_Unit" Width="1.5*" IsReadOnly="True" Foreground="LightGray"
                        ElementStyle="{StaticResource TextBlockStyle}"
                        Binding="{Binding Unit}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Margin="0,4,0,0" Visibility="{Binding ElementName=Crosshair_Show, Path=IsChecked, Converter={StaticResource b2v}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                       Text="Crosshair Color" />
                            <ComboBox Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" Height="20"
                                      Name="Crosshair_Color" />
                            <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" 
                                       Text="Crosshair LineStyle" />
                            <ComboBox Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" Height="20"
                                     Name="Crosshair_LineStyle" Text="16"/>
                        </Grid>
                        <!--Grid Margin="0,4,0,0" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Selected Plot " />
                            <TextBox Grid.Column="1" Margin="0,0,4,0" Text="{Binding ActiveIndexText}" IsReadOnly="True"
                                     VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="Prev" Height="18" Width="40" 
                                    Command="{Binding PrevActiveIndexCommand}"/>
                            <Button Grid.Column="3" Content="Next" Height="18" Width="40"
                                    Command="{Binding NextActiveIndexCommand}"/>
                        </Grid-->
                    </StackPanel>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Span Selection
                        </TextBlock>
                    </Expander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <CheckBox Margin ="0,8,0,0" VerticalContentAlignment="Center" 
                                   Name="Hor_Span" Content="Show Horizontal Span" IsChecked="False"/>
                        </Grid>
                        <Grid Grid.Row="1" Visibility="{Binding ElementName=Hor_Span, Path=IsChecked, Converter={StaticResource b2v}}">
                            <StackPanel>
                                <DataGrid RowHeight="24" Margin="0,8,0,0" Name="XSpanDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                                        <DataGridTemplateColumn Header="_Value" Width="3*" >
                                            <DataGridTemplateColumn.CellTemplate >
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayValue}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}" Loaded="EditingTextBox_Loaded"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="_Unit" Width="1.5*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Margin="0,4,0,0"  >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                       Text="Horizontal Span Color" />
                                    <ComboBox Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" Height="20"
                                      Name="X_Span_FillColor" />
                                    <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center"
                                       Text="Horizontal Color Opacity" />
                                    <ComboBox Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" Height="20"
                                      Name="X_Span_Opacity" />
                                    <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" 
                                      Text="Horizontal LineStyle" />
                                    <ComboBox Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" Height="20"
                                      Name="X_Span_LineStyle" Text="16"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="2">
                            <CheckBox Margin ="0,8,0,0" VerticalContentAlignment="Center" Grid.Row="2"
                                   Name="Ver_Span" Content="Show Vertical Span" IsChecked="False"/>
                        </Grid>
                        <Grid Grid.Row="3" Visibility="{Binding ElementName=Ver_Span, Path=IsChecked, Converter={StaticResource b2v}}">
                            <StackPanel>
                                <DataGrid RowHeight="24" Margin="0,8,0,0" Name="YSpanDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                                        <DataGridTemplateColumn Header="_Value" Width="3*" >
                                            <DataGridTemplateColumn.CellTemplate >
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayValue}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}" Loaded="EditingTextBox_Loaded"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="_Unit" Width="1.5*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Margin="0,4,0,0"  >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                       Text="Vertical Span Color" />
                                    <ComboBox Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" Height="20"
                                      Name="Y_Span_FillColor" />
                                    <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center"
                                       Text="Vertical Color Opacity" />
                                    <ComboBox Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" Height="20"
                                      Name="Y_Span_Opacity" />
                                    <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" 
                                      Text="Vertical LineStyle" />
                                    <ComboBox Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" Height="20"
                                      Name="Y_Span_LineStyle" Text="16"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Expander>
            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
