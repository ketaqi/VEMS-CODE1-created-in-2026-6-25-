<UserControl x:Class="VEMS.Plot.FrameLite"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ScottPlot="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
             xmlns:local="clr-namespace:VEMS.Plot"
             mc:Ignorable="d" Background="White"
             d:DesignHeight="600" d:DesignWidth="740" >
    
    <ScottPlot:WpfPlot Grid.Row="1" Grid.Column="0" Margin="2" 
             BorderThickness="0.5" BorderBrush="LightGray"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             Focusable="False" AllowDrop="True" Name="PlotFrame">
    </ScottPlot:WpfPlot>
    
</UserControl>

