                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="2" Height="20" />
                            <Label Grid.Row="2" Content="Visual Option"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="3" Content="Line Thickness"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="4" Content="Line Style"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="5" Content="Line Color"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="6" Content="Marker Size"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="7" Content="Marker Style"/>
                            <ComboBox Grid.Row="7" Grid.Column="1" Margin="2" Height="20"/>
                            <Label Grid.Row="8" Content="Marker Color"/>
                            <ComboBox Grid.Row="8" Grid.Column="1" Margin="2" Height="20"/>
                        </Grid>
                    </Expander>-->
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            View Ranges
                        </TextBlock>
                    </Expander.Header>
                    <DataGrid RowHeight="24" Margin="0,8,0,0" Name="RangeDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                            <DataGridTextColumn Header="_Value" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                            <DataGridTextColumn Header="_Unit" Width="1.5*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Axis Ticks
                        </TextBlock>
                    </Expander.Header>
                    <DataGrid RowHeight="24" Margin="0,8,0,0" Name="TickDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                            <DataGridTextColumn Header="_Density" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                            <DataGridTextColumn Header="_Size" Width="1.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Title, Label
                        </TextBlock>
                    </Expander.Header>
                    <DataGrid RowHeight="24" Margin="0,8,0,0" Name="TextDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                            <DataGridTextColumn Header="_Content" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                            <DataGridTextColumn Header="_Size" Width="1.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Value Monitor
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid RowHeight="24" Margin="0,8,0,0" Name="CursorDataGrid" ItemsSource="{Binding}"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Name}" />
                                <DataGridTextColumn Header="_Value" Width="2.5*" 
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Value}" />
                                <DataGridTextColumn Header="_Unit" Width="1.5*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <!--Grid Margin="0,4,0,0" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Selected Plot " />
                            <TextBox Grid.Column="1" Margin="0,0,4,0" Text="{Binding ActiveIndexText}" IsReadOnly="True"
                                     VerticalAlignment="Center" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="Prev" Height="18" Width="40" 
                                    Command="{Binding PrevActiveIndexCommand}"/>
                            <Button Grid.Column="3" Content="Next" Height="18" Width="40"
                                    Command="{Binding NextActiveIndexCommand}"/>
                        </Grid-->
                    </StackPanel>
                </Expander>
                
            </StackPanel>
        </ScrollViewer>
        
        
    </Grid>
    
    
</Window>
