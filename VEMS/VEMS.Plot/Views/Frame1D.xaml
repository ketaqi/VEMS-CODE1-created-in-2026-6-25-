<Window x:Class="VEMS.Plot.Frame1D"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VEMS.Plot" 
        mc:Ignorable="d"
        Title="Frame1D" Height="600" Width="1080" >

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="b2v" />
        <Style TargetType="DataGrid" x:Key="DataGridStyle">
            <Style.Setters>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="HeadersVisibility" Value="None"/>
                <!--Setter Property="RowHeight" Value="22"/-->
                <Setter Property="VerticalGridLinesBrush" Value="LightGray"/>
                <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DataGridRow" x:Key="DataGridRowStyle">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock" x:Key="TextBlockStyle">
            <Style.Setters>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
    </Window.Resources>

    <Grid ShowGridLines="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" Name="PlotColumn"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="340" Name="AdvColumn"/>
        </Grid.ColumnDefinitions>

        <GridSplitter Grid.Column="1" Grid.Row="1" Width="2" Name="Splitter"
                      VerticalAlignment="Stretch" HorizontalAlignment="Center"
                      Background="Transparent" ShowsPreview="True">
        </GridSplitter>

        <Menu Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            <MenuItem Header="_File" Height="24">
            </MenuItem>
            <MenuItem Header="_Functions" Height="24">
                <MenuItem Header="_Show Data Label" Click="ShowDataLabel_Click" />
            </MenuItem>
            <CheckBox Content="_Advanced Options" Name="AdvCheckBox"
                      IsChecked="True"
                      Checked="AdvCheckBox_Checked"
                      Unchecked="AdvCheckBox_Unchecked"/>
        </Menu>

        <WpfPlot Grid.Row="1" Grid.Column="0" Margin="2" 
                 BorderThickness="0.5" BorderBrush="LightGray"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 Focusable="False" AllowDrop="True" Name="PlotFrame">
        </WpfPlot>

        <ScrollViewer Grid.Row="1" Grid.Column="2" Margin="2"
                      BorderBrush="LightGray" BorderThickness="0.5"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsChecked, ElementName=AdvCheckBox, Converter={StaticResource b2v}}">
            <StackPanel Margin="10,5,10,5" Orientation="Vertical">

                <Button Padding="2" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent"
                        Click="PlotButton">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Margin="2,0,2,0" Points="0,6 12,13 0,20 0,6" Fill="LightSteelBlue"
                                 Stroke="Black" StrokeThickness="2"></Polygon>
                        <TextBlock Margin="4" Foreground="Black"  FontSize="14" Text="Plot/Update" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Expander Margin="0,8,0,8" IsEnabled="True" >
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Data Sources
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel Name="DataSourcePanel" />
                    <!--<Expander Margin="0, 8, 0, 0">
                        <Expander.Header>
                            <TextBlock FontSize="12" Foreground="DimGray" FontWeight="SemiBold"> 
                                Data Type 
                            </TextBlock>
                        </Expander.Header>
                        <Grid Margin="0, 4, 0, 4" ShowGridLines="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="4*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Row="0" Content="Data Label"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin ="2" Height="20" VerticalContentAlignment="Center" />
