<Window x:Class="VEMS.Plot.PlotMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VEMS.Plot" 
        d:DataContext="{d:DesignInstance Type=local:PlotMenuViewModel}"
        mc:Ignorable="d"
        Title="PlotMenu" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="300"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Button Grid.Column="0" Grid.Row="0" Width="192" Margin="5"
                Content="GridFig1D (Single Data)" Command="{Binding GridFig1DCommand}" >
        </Button>
        <Button Grid.Column="0" Grid.Row="1" Width="192" Margin="5"
                Content="GridFig1D (Multi Data)" Command="{Binding GridFig1DMultiCommand}">
        </Button>
        <Button Grid.Column="0" Grid.Row="2" Width="192" Margin="5"
                Content="Fig2D (Single Data)" Command="{Binding GridFig2DCommand}">
        </Button>
        <Button Grid.Column="0" Grid.Row="3" Width="192" Margin="5"
                Content="Fig2D (Single Data)" Command="{Binding GridFig2DMultiCommand}" >
        </Button>
        <Button Grid.Column="0" Grid.Row="4" Width="192" Margin="5"
                Content="Frame1D" Command="{Binding Frame1DCommand}">
        </Button>
        <Button Grid.Column="0" Grid.Row="5" Width="192" Margin="5"
                Content="FrameExt in Window" Command="{Binding VFrameCommand}">
        </Button>

        <local:FrameLite Grid.Column="0" Grid.Row="6">
        </local:FrameLite>
        <TextBox Grid.Column="0" Grid.Row="7" >
        </TextBox>

    </Grid>
</Window>
