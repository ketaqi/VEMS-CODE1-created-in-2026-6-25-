<UserControl x:Class="VEMS.Plot5.Frame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VEMS.Plot5"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF" d:DataContext="{d:DesignInstance Type=local:FrameViewModel}"
             mc:Ignorable="d" Background="White"
             d:DesignHeight="600" d:DesignWidth="1080" >

    <UserControl.Resources>
        <!--<BooleanToVisibilityConverter x:Key="b2v" />-->
        <Style TargetType="DataGrid" x:Key="DataGridStyle">
            <Style.Setters>
                <Setter Property="Margin" Value="0,8,0,0"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserSortColumns" Value="False"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="RowHeight" Value="24"/>
                <Setter Property="TextBlock.FontStyle" Value="Normal"/>
                <Setter Property="VerticalGridLinesBrush" Value="LightGray"/>
                <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DataGridRow" x:Key="DataGridRowStyle">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock" x:Key="TextBlockStyle">
            <Style.Setters>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="Button" x:Key="ButtonStyle">
            <Style.Setters>
                <Setter Property="Background" Value="WhiteSmoke"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
                <Setter Property="Width" Value="72"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding AdvWidth}" x:Name="AdvColumn"/>
        </Grid.ColumnDefinitions>

        <ScottPlot:WpfPlot x:Name="Dock" Margin="2"
                   HorizontalAlignment="Stretch" 
                   VerticalAlignment="Stretch">
        </ScottPlot:WpfPlot>
        <GridSplitter Grid.Column="1" Width="5" Background="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ShowsPreview="True">
        </GridSplitter>
        <ScrollViewer x:Name="AdvOption" Grid.Column="2" Margin="2"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding AdvOption}">
            <StackPanel Margin="10,5,10,5" Orientation="Vertical">

                <Button Padding="2" HorizontalAlignment="Left" 
                        Background="Transparent" BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Margin="2,0,2,0" Points="0,6 12,13 0,20 0,6" Fill="LightSteelBlue"
                                  Stroke="Black" StrokeThickness="2"/>
                        <TextBlock Margin="4" Foreground="Black" FontSize="14" Text="Update" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Expander Margin="0,8,0,8" IsEnabled="True" >
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            Plot Property
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel x:Name="PlotPropertyPanel" />
                </Expander>
                <Expander Margin="0,8,0,8" IsEnabled="True">
                    <Expander.Header>
                        <TextBlock FontSize="14" Foreground="SteelBlue" FontWeight="SemiBold">
                            View Ranges
                        </TextBlock>
                    </Expander.Header>
                    <StackPanel>
                        <DataGrid x:Name ="RangeDataGrid" Style="{StaticResource DataGridStyle}" 
                                  RowStyle="{StaticResource DataGridRowStyle}"
                                  ItemsSource="{Binding}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="_Property" Width="4.0*" IsReadOnly="True"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                />
                                <DataGridTemplateColumn Header="_Value" Width="3*" >
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="123" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="234" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="_Unit" Width="*" IsReadOnly="True" Foreground="LightGray"
                                                ElementStyle="{StaticResource TextBlockStyle}"
                                                Binding="{Binding Unit}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="4,0,4,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto X"/>
                            <Button Grid.Column="1" Margin="4,0,4,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto Y" />
                            <Button Grid.Column="2" Margin="4,0,2,0" Style="{StaticResource ButtonStyle}"
                                    Content="Auto X+Y" />
                        </Grid>

                    </StackPanel>


                </Expander>


            </StackPanel>
        </ScrollViewer> 
    </Grid>
    
    

</UserControl>
