<UserControl x:Class="VEMS.WorkBench.CloseableHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VEMS.WorkBench"
             mc:Ignorable="d" Height="16">
    
    
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Name="columnLabel" Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Name="columnCloseButton" Width="16"/>
        </Grid.ColumnDefinitions>

        <Label Name="HeaderLabel" Content="TabItem" Height="16" Padding="0"
               HorizontalAlignment="Left" VerticalAlignment="Top" />

        <Button Grid.Column="2" FontFamily="/Fonts/#iconfont" Content="&#xe679;" Height="16" 
                HorizontalAlignment="Right" Margin="0" Name="CloseButton" VerticalAlignment="Top" Width="16" 
                Visibility="Visible" Padding="0" ToolTip="Close" 
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
        
    </Grid>
</UserControl>
