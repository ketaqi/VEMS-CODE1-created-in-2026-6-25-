<Window x:Class="VEMS.WorkBench.ImageSizeSp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ImageSizeJsp" Height="180" Width="300" MaxWidth="300" MaxHeight="180">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ButtonStyle">
            <Style.Setters>
                <Setter Property="Background" Value="WhiteSmoke"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
                <Setter Property="Width" Value="72"/>
            </Style.Setters>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel >
            <Grid Margin="10,4,10,0"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                       Text="View Width" />
                <Grid Grid.Column="1" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"  VerticalContentAlignment="Center"  Height="20"
                                     BorderThickness="1.5" BorderBrush="LightGray"
                                     Name="View_Width" 
                             InputMethod.IsInputMethodEnabled="False"
                             PreviewTextInput="TextBox_PreviewTextInput"/>
                    <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" Width="40" Height="20"
                                    Content="Auto" Click="ViewWidth_Auto"/>
                </Grid>
                
                

                <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" 
                                       Text="View Height" />
                <Grid Grid.Column="1" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"  VerticalContentAlignment="Center" Height="20"
                                     BorderThickness="1.5" BorderBrush="LightGray"
                                     Name="View_Height"  Grid.ColumnSpan="4" 
                                    InputMethod.IsInputMethodEnabled="False"
                                    PreviewTextInput="TextBox_PreviewTextInput" />
                    <Button Grid.Column="1" Style="{StaticResource ButtonStyle}" Width="40" Height="20"
                                    Content="Auto" Click="ViewHeight_Auto"/>
                </Grid>
                
                

                <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" 
                                       Text="View_lowQuality" />
                <ComboBox Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" Height="20" 
                                      Name="View_lowQuality" >
                    <ComboBoxItem Content="False" IsSelected="True" Height="20"/>
                    <ComboBoxItem Content="True" Height="20"/>
                </ComboBox>
                <TextBlock Grid.Column="0" Grid.Row="3" VerticalAlignment="Center" 
                                       Text="Scale" />
                <TextBox Grid.Column="1" Grid.Row="3" VerticalContentAlignment="Center" Height="20"
                                     BorderThickness="1.5" BorderBrush="LightGray"
                                     Name="View_Scale" Text="1"/>
            </Grid>
            <Grid HorizontalAlignment="Right" Margin="0,4,10,0">
                <Button Grid.Column="0"  Style="{StaticResource ButtonStyle}"
                                    Content="Save" Click="Button_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
