<Window x:Class="VEMS.WorkBench.VEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VEMS.WorkBench" 
        xmlns:Fluent="urn:fluent-ribbon"
        d:DataContext="{d:DesignInstance Type=local:VEditorModel}"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="900" Width="1600">

  
    <Window.Resources>
        <SolidColorBrush Color="#E5E5E5" x:Key="MenuColor"/>
        <SolidColorBrush Color="WhiteSmoke" x:Key="TreeColor"/>
        <SolidColorBrush Color="White" x:Key="EditorColor"/>
        <SolidColorBrush Color="White" x:Key="ConsoleColor"/>
        <SolidColorBrush Color="Transparent" x:Key="SplitterColor"/>
        <SolidColorBrush Color="Gray" x:Key="SiderColor" />
        <SolidColorBrush Color="WhiteSmoke" x:Key="ButtonColor" />
        <SolidColorBrush Color="#ECECEC" x:Key="TabColor"/>
        <SolidColorBrush Color="LightSteelBlue" x:Key="BottomColor"/>

        <Style TargetType="DataGrid" x:Key="DataGridStyle">
            <Style.Setters>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="HeadersVisibility" Value="None"/>
                <!--Setter Property="RowHeight" Value="22"/-->
                <Setter Property="VerticalGridLinesBrush" Value="LightGray"/>
                <Setter Property="HorizontalGridLinesBrush" Value="LightGray"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DataGridRow" x:Key="DataGridRowStyle">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock" x:Key="TextBlockStyle">
            <Style.Setters>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TabItem" x:Key="TabItemStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Name="Panel">
                            <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ContentSource="Header"
                                        Margin="10,2"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="LightSkyBlue" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Panel" Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="ButtonStyle">
            <Style.Setters>
                <Setter Property="Background" Value="WhiteSmoke"/>
                <Setter Property="BorderBrush" Value="LightGray"/>
                <Setter Property="Width" Value="72"/>
            </Style.Setters>
        </Style>

    </Window.Resources>
    <Window.InputBindings>
        <!--<KeyBinding Gesture="Ctrl+N" Command="{StaticResource ShortCutNew}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{StaticResource ShortCutOpen}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{StaticResource ShortCutSave}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{StaticResource ShortCutSaveAs}"/>
        <KeyBinding Gesture="Ctrl+F4" Command="{StaticResource ShortCutCloseTab}"/>
        <KeyBinding Gesture="Ctrl+F" Command="{StaticResource ShortCutFind}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{StaticResource ShortCutReplace}"/>
        <KeyBinding Gesture="Ctrl+Alt+F" Command="{StaticResource ShortCutFormat}"/>
        <KeyBinding Gesture="Ctrl+Alt+C" Command="{StaticResource ShortCutComment}"/>
        <KeyBinding Gesture="Ctrl+Alt+U" Command="{StaticResource ShortCutUncomment}"/>
        <KeyBinding Gesture="F5" Command="{StaticResource ShortCutDiagnostic}"/>
        <KeyBinding Gesture="Ctrl+F5" Command="{StaticResource ShortCutRun}"/>
        <KeyBinding Gesture="Ctrl+Alt+D" Command="{StaticResource ShortCutClearMessage}"/>-->
        
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewEmptyCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+F4" Command="{Binding CloseAllVFramesCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveFileAsCommand}"/>
        <KeyBinding Gesture="Ctrl+F4" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FindCommand}"/>
        <KeyBinding Gesture="Ctrl+H" Command="{Binding ReplaceCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+F" Command="{Binding FormatCodeCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+C" Command="{Binding CommentLinesCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+U" Command="{Binding UncommentLinesCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding CompileDiagnosticCommand}"/>
        <KeyBinding Gesture="Ctrl+F5" Command="{Binding RunCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+D" Command="{Binding ClearConsoleCommand}"/>
    </Window.InputBindings>

    <Grid ShowGridLines="false">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"></ColumnDefinition>
            <ColumnDefinition Width="1.67*"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="5*"></ColumnDefinition>
            <ColumnDefinition Width="2"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="24"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="2" Grid.RowSpan="3" Background="{StaticResource SiderColor}" />
        <GridSplitter Grid.Column="2" Grid.Row="2" Grid.RowSpan="3" Width="5" VerticalAlignment="Stretch"
                      HorizontalAlignment="Center" Background="{StaticResource SplitterColor}"  ShowsPreview="True"></GridSplitter>
        <Border Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="5" Background="{StaticResource BottomColor}"/>

        <Fluent:Ribbon Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4">
            <Fluent:Ribbon.Menu>
                <Fluent:Backstage Header="VEMS">
                    <Fluent:BackstageTabControl>
                        <Fluent:BackstageTabItem Header="Info"/>
                        <Fluent:BackstageTabItem Header="Exit"/>
                    </Fluent:BackstageTabControl>
                </Fluent:Backstage>
            </Fluent:Ribbon.Menu>
            <Fluent:RibbonTabItem Header="File">
                <Fluent:RibbonGroupBox Header="file">
                    <Fluent:Button Header="_New file" Width="64" 
                                   Command="{Binding NewEmptyCommand}"
                                   KeyTip="Ctrl+N">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe665;"
                                       ToolTip="Ctrl+N"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Open file" Width="64"
                                   Command="{Binding OpenFileCommand}"
                                   KeyTip="Ctrl+O">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe69d;"
                                       ToolTip="Ctrl+O"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="folder">
                    <Fluent:Button Header="_Open Folder" Width="64"
                                   Command="{Binding OpenNewFolderCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6a4;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Default Folder" Width="64"
                                   Command="{Binding OpenDefaultFolderCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe69e;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="save">
                    <Fluent:Button Header="_Save file" Width="64"
                                   Command="{Binding SaveFileCommand}" 
                                   KeyTip="Ctrl+S" >
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe66e;"
                                       ToolTip="Ctrl+S"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Save as" Width="64"
                                   Command="{Binding SaveFileAsCommand}" 
                                   KeyTip="Ctrl+Shift+S" >
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe693;"
                                       ToolTip="Ctrl+Shift+S"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Save all" Width="64"
                                   Command="{Binding SaveAllFilesCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6ad;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="close">
                    <Fluent:Button Header="_Close tab" Width="64"
                                   Command="{Binding CloseFileCommand}" 
                                   KeyTip="Ctrl+F4">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe679;"
                                       ToolTip="Ctrl+F4"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Close all" Width="64"
                                   Command="{Binding CloseAllFilesCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe696;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Exit app" Width="64"
                                   Command="{Binding ExitAppCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6a1;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="tests..." Visibility="Hidden">
                    <Fluent:Button Header="Rename"  
                                   IsEnabled="False" />
                    <Fluent:Button Header="VFrames Info"
                                   Command="{Binding CheckVFrameInfoCommand}"/>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
            <Fluent:RibbonTabItem Header="Code">
                <Fluent:RibbonGroupBox Header="search">
                    <Fluent:Button Header="_Search text" Width="64"
                                   Command="{Binding FindCommand}"
                                   KeyTip="Ctrl+F">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe690;"
                                       ToolTip="Ctrl+F"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Replace text" Width="64"
                                   Command="{Binding ReplaceCommand}"
                                   KeyTip="Ctrl+H">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6dc;"
                                       ToolTip="Ctrl+H"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="format">
                    <Fluent:Button Header="_Format code" Width="64"
                                   Command="{Binding FormatCodeCommand}"
                                   KeyTip="Ctrl+Alt+F">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6b6;"
                                       ToolTip="Ctrl+Alt+F"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="comment">
                    <Fluent:Button Header="_Comment selection" Width="64"
                                   Command="{Binding CommentLinesCommand}"
                                   KeyTip="Ctrl+Alt+C">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe673;"
                                       ToolTip="Ctrl+Alt+C"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Uncomment selection" Width="80"
                                   Command="{Binding UncommentLinesCommand}"
                                   KeyTip="Ctrl+Alt+U">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe671;"
                                       ToolTip="Ctrl+Alt+U"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="compile">
                    <Fluent:Button Header="_Debug code" Width="64"
                                   Command="{Binding CompileDiagnosticCommand}" 
                                   KeyTip="F5">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6b3;"
                                       ToolTip="F5"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Run code" Width="64"
                                   Command="{Binding RunCommand}"
                                   KeyTip="Ctrl+F5">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6ed;"
                                       ToolTip="Ctrl+F5"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Run (STA)" Width="64"
                                   Command="{Binding RunSTACommand}"
                                   Visibility="Collapsed" >
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe66c;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="coding">
                    <Fluent:Button Header="_Add class" Width="64"
                                   Command="{Binding AddClassCommand}"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe678;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Add method" Width="64"
                                   Command="{Binding AddMethodCommand}"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe678;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="task" Visibility="Hidden">
                    <Fluent:Button Header="_Start task" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False"/>
                    <Fluent:Button Header="_Stop task" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False"/>
                    <Fluent:Button Header="_Check Status" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False"/>
                    <Fluent:Button Header="_Script" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False"/>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
            <Fluent:RibbonTabItem Header="Output">
                <Fluent:RibbonGroupBox Header="message">
                    <Fluent:Button Header="_Copy message" Width="64"
                                   Command="{Binding CopyConsoleTextCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6d5;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Clear message" Width="64"
                                   Command="{Binding ClearConsoleCommand}"
                                   KeyTip="Ctrl+Alt+D">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6c4;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="figures">
                    <Fluent:Button Header="_All figures minimized" Width="64"
                                   Command="{Binding MinimizeAllVFramesCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6ac;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Close all figures" Width="64"
                                   Command="{Binding CloseAllVFramesCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe696;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="tests ..." Visibility="Hidden">
                    <Fluent:Button Header="Delete Plot" Width="64"
                                   Command="{Binding DeleteVFrameCommand}"/>
                    <Fluent:Button Header="Show Selected VFrame Index" Width="64"
                                   Command="{Binding ShowSelectedVFrameIndexCommand}"/>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
            <Fluent:RibbonTabItem Header="Network" IsEnabled="False" >
                <Fluent:RibbonGroupBox Header="info">
                    <Fluent:Button Header="_Check Info" Width="64"
                                   Command="{Binding CheckIPInfoCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6c2;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:ComboBox Width="128" Header="IP" ItemsSource="{Binding Ips}"
                                     SelectedItem="{Binding Ip, Mode=TwoWay}" />
                    <Fluent:TextBox Header="Port" Text="{Binding Port}" Visibility="Hidden" />
                    <Label Content="... of this computer"/>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="service" Visibility="Collapsed">
                    <Fluent:Button Header="_Enable service" Width="64"
                                   Command="{Binding EnableParallelServiceCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6ad;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Start as node" Width="64"
                                   Command="{Binding StartAsNodeCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6d3;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Stop service" Width="64" 
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6d0;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Check status" Width="64"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6a3;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="connection" Visibility="Collapsed">
                    <Fluent:Button Header="_Hello to ..." Width="64"
                                   Command="{Binding LinkToCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6da;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:TextBox Header="IP" Text="{Binding IpTarget}" />
                    <Fluent:TextBox Header="Port" Text="{Binding PortTarget}" />
                    <Label Content="... of target computer"/>
                    <Fluent:Button Header="_Link to ..." Width="64"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6d5;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="run">
                    <Fluent:Button Header="_Run..." Width="64"
                                   Command="{Binding RunCommand}"
                                   IsEnabled="true" >
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe66c;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
            <Fluent:RibbonTabItem Header="Help">
                <Fluent:RibbonGroupBox Header="welcome" Visibility="Collapsed">
                    <Fluent:Button Header="_Welcome" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe697;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="help">
                    <Fluent:Button Header="_Get started" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6b0;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_VEMS Docs" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe677;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Links" Width="64"
                                   Command="{Binding }"
                                   IsEnabled="False">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6c0;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Help" Width="64"
                                   Command="{Binding PrintHelpInfoCommand}"
                                   IsEnabled="True">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6b4;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="license">
                    <Fluent:Button Header="_License info" Width="64"
                                   Command="{Binding PrintLicenseInfoCommand}"
                                   IsEnabled="True">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6df;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Update app" Width="64"
                                    Command="{Binding OpenDownloadPageForVEMSCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe68D;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="about">
                    <Fluent:Button Header="_About VEMS" Width="64"
                                   Command="{Binding PrintAboutInfoCommand}">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6c0;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
                    <Fluent:Button Header="_Contact us" Width="64"
                                   Command="{Binding PrintContactInfoCommand}"
                                   IsEnabled="True">
                        <Fluent:Button.LargeIcon>
                            <TextBlock Foreground="DimGray"
                                       FontSize="32"
                                       FontFamily="/Fonts/#iconfont"
                                       Text="&#xe6dd;"/>
                        </Fluent:Button.LargeIcon>
                    </Fluent:Button>
