                        <Button Grid.Row="3" Grid.Column="2" Content="Auto" IsEnabled="False"
                            Width="64" Margin="0,4,0,4"/>

                    </Grid>
                    <Separator/>
                    <Grid Background="LightGray">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Benchmark" Foreground="DimGray" FontWeight="Bold"/>
