            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,2,10,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="353*"/>
                    <RowDefinition Height="118*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" >
                    <Label Content="Code Editor" Foreground="SteelBlue"
                       FontSize="24" FontWeight="Normal" />
                </StackPanel>
                <Separator Grid.Row="1" Margin="0,2,0,2"/>
                <TabControl Grid.Row="1" Name="tabs" ItemsSource="{Binding VEditTabs}"
                            BorderThickness="0.0" SelectedIndex="{Binding SelectedTabIndex}" Margin="0,5,0,5" Grid.RowSpan="4">
                    <TabControl.Resources>
                        <Style TargetType="local:REditTab">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="Gainsboro" CornerRadius="2,2,0,0" Margin="1,0">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                              ContentSource="Header" Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="LightSteelBlue" />
                                                <Setter Property="TextElement.FontWeight" TargetName="ContentSite" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="WhiteSmoke" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                </TabControl>
                <Separator Grid.Row="4" Margin="0,2,0,2"/>
            </Grid>
            <GridSplitter Grid.Row="1" Height="5" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                          Background="{StaticResource SplitterColor}" ShowsPreview="True">
            </GridSplitter>
            <Grid Grid.Row="2" Margin="10,2,10,2" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Label Content="Output" Foreground="SteelBlue"
                       FontSize="24" FontWeight="Normal" />
                </StackPanel>
                <Separator Grid.Row="1"></Separator>
                <TabControl Grid.Row="2" BorderThickness="0.0" >
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="Gainsboro" CornerRadius="2,2,0,0" Margin="1,0">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                              ContentSource="Header" Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="LightSteelBlue" />
                                                <Setter Property="TextElement.FontWeight" TargetName="ContentSite" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="WhiteSmoke" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="Messages">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10*"></ColumnDefinition>
                                <ColumnDefinition Width="40"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBox Margin="0,4,0,0" Height="Auto"  Grid.Column="0"
                                 x:Name="txtBox_Console" VerticalAlignment="Stretch"
                                 TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" 
                                 BorderBrush="LightGray" BorderThickness="0.0" Foreground="DimGray"
                                 FontFamily="{Binding VConsole.FontFamily}"
                                 FontSize="{Binding VConsole.FontSize}" 
                                 Text="{Binding VConsole.Content}">
                                                    </TextBox>
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"></RowDefinition>
                                    <RowDefinition Height="auto"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" >
                                    <Button  VerticalAlignment="Bottom" Background="transparent" BorderBrush="Transparent"  
                                             Command="{Binding CopyConsoleTextCommand}" ToolTip="Copy message" ToolTipService.InitialShowDelay="100">
                                        <TextBlock Foreground="DimGray" FontSize="32" FontFamily="/Fonts/#iconfont"
                                        Text="&#xe6d5;"  VerticalAlignment="Top"/>
                                    </Button>
                                </Grid>
                                <Grid Grid.Row="1" >
                                    <Button  VerticalAlignment="Bottom" Background="transparent" BorderBrush="Transparent" 
                                             Command="{Binding ClearConsoleCommand}" ToolTip="Clear message" ToolTipService.InitialShowDelay="100">
                                        <TextBlock Foreground="DimGray" FontSize="32" FontFamily="/Fonts/#iconfont"
                                        Text="&#xe6c4;"  VerticalAlignment="Bottom"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Figures">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10*"></ColumnDefinition>
                                <ColumnDefinition Width="40"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <DataGrid Grid.Column="0"  RowHeight="24" Margin="0,4,0,0" Background="Transparent"
                              TextBlock.FontStyle="Normal" CanUserSortColumns="False"
                              Style="{StaticResource DataGridStyle}" HeadersVisibility="Column"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              ItemsSource="{Binding AppFrames}"
                              SelectedIndex="{Binding SelectedVFrameIndex}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="_Plot Document" Width="3*"
                                        ElementStyle="{StaticResource TextBlockStyle}"
                                        Binding="{Binding DocName}"/>
                                    <DataGridTemplateColumn Header="_Manipulation" Width="4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                        <Button Content="Show up" Grid.Column="0" Height="20" Margin="2,0,2,0"
                                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                            Command="{Binding DataContext.ShowUpSelectedVFrameCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"/>
                                                        <Button Content="Minimize" Grid.Column="1" Height="20" Margin="2,0,2,0"
                                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                            Command="{Binding DataContext.MinimizeSelectedVFrameCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"/>
                                                    <Button Content="Close" Grid.Column="2" Height="20" Margin="2,0,2,0"
                                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                            Command="{Binding DataContext.CloseSelectedVFrameCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="_User Comment" Width="9*"
                                         ElementStyle="{StaticResource TextBlockStyle}"
                                         Binding ="{Binding UserComment}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid Grid.Column="1"  Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"></RowDefinition>
                                    <RowDefinition Height="auto"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" >
                                    <Button  VerticalAlignment="Bottom" Background="transparent" BorderBrush="Transparent"  
                                        Command="{Binding MinimizeAllVFramesCommand}" ToolTip="All figures minimized" ToolTipService.InitialShowDelay="100">
                                        <TextBlock Foreground="DimGray" FontSize="32" FontFamily="/Fonts/#iconfont"
                                            Text="&#xe6ac;"  VerticalAlignment="Top"/>
                                    </Button>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Button  VerticalAlignment="Bottom" Background="transparent" BorderBrush="Transparent" 
                                        Command="{Binding CloseAllVFramesCommand}" ToolTip="Close all figures" ToolTipService.InitialShowDelay="100">
                                        <TextBlock Foreground="DimGray" FontSize="32" FontFamily="/Fonts/#iconfont"
                                            Text="&#xe696;"  VerticalAlignment="Bottom"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                        
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

    </Grid>

</Window>
