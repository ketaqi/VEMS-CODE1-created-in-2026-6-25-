<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:roslynPad="using:RoslynPad"
             xmlns:roslyn="clr-namespace:Microsoft.CodeAnalysis;assembly=Microsoft.CodeAnalysis"
             xmlns:ui="using:RoslynPad.UI"
             x:Class="RoslynPad.DocumentTreeView4"
             x:DataType="roslynPad:MainViewModelAvalonia">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 空白分隔行 -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <TextBlock Text="{Binding Localized[MainWindow.leftMenuItem11]}" VerticalAlignment="Center" Width="150" HorizontalAlignment="Center" FontSize="20"/>
        </StackPanel>
        <Border Grid.Row="1" Height="1" Background="#DDDDDD" Margin="8,0,8,0"/>
        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="2">
            <TextBlock Text="4444" VerticalAlignment="Center" Width="150" HorizontalAlignment="Center" FontSize="20"/>
        </StackPanel>
    </Grid>
</UserControl>
