    </AvaloniaResource>
    <AvaloniaResource Include="Resources\zhuti-H.png" />
    <AvaloniaResource Include="Resources\zhuti.png" />

    <AvaloniaXaml Remove="bin\**\*.axaml;obj\**\*.axaml" />
