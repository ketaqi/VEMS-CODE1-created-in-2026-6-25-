<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType Condition=" '$(IsMacOS)' == 'true' ">Exe</OutputType>
    <OutputType Condition=" '$(IsMacOS)' != 'true' ">WinExe</OutputType>
    <AssemblyName>RoslynPad</AssemblyName>
    <RootNamespace>RoslynPad</RootNamespace>
    <ApplicationId>net.roslynpad</ApplicationId>
    <ApplicationTitle>RoslynPad</ApplicationTitle>

    <Version>$(RoslynPadVersion)</Version>
    <TargetFramework Condition=" '$(IsMacBuild)' == 'true' ">$(DefaultTargetFramework)-macos</TargetFramework>
    <CopyRoslynPadRuntimeAssemblies>true</CopyRoslynPadRuntimeAssemblies>
    <SelfContained>false</SelfContained>
    <CreatePackage>false</CreatePackage>
    <LinkMode>None</LinkMode>
    <TrimMode>partial</TrimMode>
    <!--<TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningsNotAsErrors>nullable;CS8618;CS8602;CS8625;CS8766;CS8767</WarningsNotAsErrors>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>-->
    <!-- HotAvalonia --><!--
    <HotAvaloniaAutoEnable>true</HotAvaloniaAutoEnable>
    <HotAvaloniaGeneratePathResolver>true</HotAvaloniaGeneratePathResolver>-->
  </PropertyGroup>
  <!-- hack to force resizetizer to work outside of MAUI -->
  <PropertyGroup Condition=" '$(IsMacBuild)' == 'true' ">
    <_ResizetizerIsiOSApp>true</_ResizetizerIsiOSApp>
    <ResizetizerIncludeSelfProject>true</ResizetizerIncludeSelfProject>
    <OptimizePNGs>true</OptimizePNGs>
    <_XSAppIconAssets>Assets.xcassets/appicon.appiconset</_XSAppIconAssets>
  </PropertyGroup>
  <ItemGroup>
    <MauiIcon Include="$(RepoRoot)/deploy/resources/macos/appicon.svg" />
    <EmbeddedResource Include="FontAwesome\Assets\icons.json" />
    <AvaloniaResource Include="App.axaml" />
    <AvaloniaResource Include="Assets\Localizations\en-US.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </AvaloniaResource>
    <AvaloniaResource Include="Assets\Localizations\ru-RU.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </AvaloniaResource>
    <AvaloniaResource Include="Assets\Localizations\zh-CN.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </AvaloniaResource>
    <AvaloniaResource Include="Resources\Explorer.png" />
    <AvaloniaResource Include="Resources\Explorer_Hover.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </AvaloniaResource>
    <AvaloniaResource Include="Resources\maxx-H.png" />
    <AvaloniaResource Include="Resources\maxx.png" />
    <AvaloniaResource Include="Resources\minn-H.png" />
    <AvaloniaResource Include="Resources\minn.png" />

