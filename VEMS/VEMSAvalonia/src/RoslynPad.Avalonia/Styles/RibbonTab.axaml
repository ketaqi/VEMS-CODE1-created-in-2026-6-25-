<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RoslynPad.Controls;assembly=RoslynPad">

    <Style Selector="local|RibbonTab">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Background" Value="{DynamicResource document.tree}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <ContentPresenter Content="{TemplateBinding Header}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="8,4"
                                      FontWeight="SemiBold"/>
                </Border>
            </ControlTemplate>
        </Setter>

        <!-- 悬停 hover 高亮 -->
        <Style Selector="^:pointerover">

        </Style>

        <!-- 选中状态：左、上、右边框黑色，底部无边框 -->
        <Style Selector="^:selected">
            <!-- 稍深灰色 -->
            <!--<Setter Property="BorderBrush" Value="Black"/>-->
            <!--<Setter Property="BorderThickness" Value="1,1,1,0"/>-->
            <Setter Property="Background" Value="{DynamicResource top.toolbar}"/>
        </Style>
    </Style>
</Styles>
